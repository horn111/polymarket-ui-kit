{
  "name": "@polymarket-ui-kit/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-storybook.mjs dev",
    "build": "node scripts/run-storybook.mjs build",
