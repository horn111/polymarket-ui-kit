{
  "name": "polymarket-ui-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "React-first UI primitives, data hooks, and shadcn-style registry for Polymarket apps.",
  "author": "horn111",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/horn111/polymarket-ui-kit.git"
  },
  "homepage": "https://github.com/horn111/polymarket-ui-kit#readme",
  "bugs": {
    "url": "https://github.com/horn111/polymarket-ui-kit/issues"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "storybook": "pnpm --filter @polymarket-ui-kit/storybook dev",
    "build:storybook": "pnpm --filter @polymarket-ui-kit/storybook build",
    "docs:dev": "pnpm --filter @polymarket-ui-kit/docs dev",
    "demo:dev": "pnpm --filter @polymarket-ui-kit/demo dev",
    "registry:validate": "pnpm --filter @polymarket-ui-kit/registry validate",
    "size": "tsx scripts/check-size.ts",
    "smoke": "tsx scripts/smoke-demo.ts",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.50.0",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "turbo": "^2.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vitest": "^3.0.5"
  }
}
