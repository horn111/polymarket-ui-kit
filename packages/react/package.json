{
  "name": "@polymarket-ui-kit/react",
  "version": "0.0.0",
  "description": "React components and hooks for Polymarket-powered applications.",
  "type": "module",
  "license": "MIT",
  "sideEffects": ["**/*.css"],
  "files": ["dist", "src/styles"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles/tokens.css",
    "./themes.css": "./src/styles/themes.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --root ../.. tests/unit/react.test.tsx tests/accessibility/components-a11y.test.tsx"
  },
  "dependencies": {
    "@polymarket-ui-kit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  }
}
